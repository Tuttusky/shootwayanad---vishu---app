# Google Apps Script Web App URL (Deploy → Web app → copy URL ending in /exec).
# Example (your deployment — paste uncommented into .env.local / Vercel):
# GAS_WEB_APP_URL=https://script.google.com/macros/s/AKfycbzPK30E6Fil8C45P_KSrevjnRN8CXnQCSTe8_Q-Tl2BDXPd5oBZkGDftNLYxlHdgfBbLQ/exec
GAS_WEB_APP_URL=

# Public site origin (no trailing slash). Set on Vercel to your real domain so Open Graph / WhatsApp
# link previews use the correct absolute image URL (e.g. https://www.yourdomain.com).
NEXT_PUBLIC_SITE_URL=

# Optional: override GA (defaults to G-EKFWL5FHX8 in layout if unset)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional: Microsoft Clarity project ID (defaults to w5wbjn4kp9 in layout if unset)
NEXT_PUBLIC_CLARITY_PROJECT_ID=
